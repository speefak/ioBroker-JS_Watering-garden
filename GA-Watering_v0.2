// =============================================
// Haozee 2-Zonen Ventil - mit Manual Mode
// =============================================

const buttonSingle = 'zigbee.0.a4c138068ef8ffff.single';
const buttonDouble = 'zigbee.0.a4c138068ef8ffff.double';
const buttonLong   = 'zigbee.0.a4c138068ef8ffff.long';

const valvePond    = 'zigbee.0.c02cedfffe72acf5.state_l1';
const valveFlower  = 'zigbee.0.c02cedfffe72acf5.state_l2';

const statusPond   = 'zigbee.0.c02cedfffe72acf5.valve_status_l1';
const statusFlower = 'zigbee.0.c02cedfffe72acf5.valve_status_l2';

const wateringTime = 600;                    // Sekunden
const safetyDelay  = 310000;                 // 5:10 min

// ==================== HELPER ====================

async function setManualMode(valveStatusId) {
    return new Promise(resolve => {
        setState(valveStatusId, 'manual', true, (err) => {
            if (err) log(`Fehler beim Setzen auf manual: ${err}`, 'error');
            else log(`Mode auf 'manual' gesetzt für ${valveStatusId}`, 'info');
            // Kleiner Delay damit das Gerät den Modus übernimmt
            setTimeout(resolve, 800);
        });
    });
}

function turnOn(valve, statusId, name) {
    setManualMode(statusId).then(() => {
        setState(valve, true, true);
        log(`✅ ${name} Ventil EIN`, 'info');
    });
}

function turnOff(valve, name) {
    setState(valve, false, true);
    log(`❌ ${name} Ventil AUS`, 'info');
}

function closeAll() {
    turnOff(valvePond, 'Teich');
    turnOff(valveFlower, 'Blumen');
    log('🚨 NOT-AUS: Alle Ventile geschlossen', 'warn');
}

function safetyCheck(valve, name) {
    setTimeout(() => {
        getState(valve, (err, state) => {
            if (state && state.val === true) {
                log(`⚠️ SICHERHEIT: ${name} noch AN → wird ausgeschaltet!`, 'warn');
                turnOff(valve, name);
            }
        });
    }, safetyDelay);
}

// ==================== BUTTON LOGIC ====================

on({id: buttonSingle, change: 'ne', val: true}, async () => {
    log('🔘 Single Press → Teich (Zone 1)', 'info');
    turnOn(valvePond, statusPond, 'Teich');
    safetyCheck(valvePond, 'Teich');
});

on({id: buttonDouble, change: 'ne', val: true}, async () => {
    log('🔘 Double Press → Blumen (Zone 2)', 'info');
    turnOn(valveFlower, statusFlower, 'Blumen');
    safetyCheck(valveFlower, 'Blumen');
});

on({id: buttonLong, change: 'ne', val: true}, () => {
    log('🔴 Long Press → NOT-AUS', 'warn');
    closeAll();
});

log('✅ Haozee Skript mit Manual-Mode gestartet', 'info');
