// =============================================
// Haozee Bewässerungsventil - KORREKTE Befehls-Sendung
// =============================================

const buttonSingle = 'zigbee.0.a4c138068ef8ffff.single';
const buttonDouble = 'zigbee.0.a4c138068ef8ffff.double';
const buttonLong   = 'zigbee.0.a4c138068ef8ffff.long';

const valvePond    = 'zigbee.0.c02cedfffe72acf5.state_l1';
const valveFlower  = 'zigbee.0.c02cedfffe72acf5.state_l2';

const statusPond   = 'zigbee.0.c02cedfffe72acf5.valve_status_l1';
const statusFlower = 'zigbee.0.c02cedfffe72acf5.valve_status_l2';

const wateringTime = 600;      // 10 Minuten
const safetyDelay  = 330000;   // 5:30 min

// ==================== HELPER ====================

async function setManualMode(statusId) {
    return new Promise(resolve => {
        setState(statusId, 'manual', false);   // false = Befehl
        setTimeout(resolve, 600);
    });
}

function sendCommand(valveId, value, name) {
    // WICHTIG: ack = false damit es als Befehl gesendet wird!
    setState(valveId, value, false, (err) => {
        if (err) {
            log(`Fehler beim Schalten von ${name}: ${err}`, 'error');
        } else {
            log(`Befehl gesendet: ${name} → ${value ? 'OPEN' : 'CLOSE'}`, 'info');
        }
    });
}

function turnOn(valve, statusId, name) {
    setManualMode(statusId).then(() => {
        sendCommand(valve, true, name);
    });
}

function turnOff(valve, name) {
    sendCommand(valve, false, name);
}

function closeAll() {
    turnOff(valvePond, 'Teich');
    turnOff(valveFlower, 'Blumen');
    log('🚨 NOT-AUS ausgelöst', 'warn');
}

function safetyCheck(valve, name) {
    setTimeout(() => {
        getState(valve, (err, state) => {
            if (state && state.val === true) {
                log(`⚠️ SICHERHEIT: ${name} noch offen → schließe`, 'warn');
                turnOff(valve, name);
            }
        });
    }, safetyDelay);
}

// ==================== BUTTONS ====================

on({id: buttonSingle, change: 'ne', val: true}, () => {
    log('🔘 Single Press → Teich', 'info');
    turnOn(valvePond, statusPond, 'Teich');
    safetyCheck(valvePond, 'Teich');
});

on({id: buttonDouble, change: 'ne', val: true}, () => {
    log('🔘 Double Press → Blumen', 'info');
    turnOn(valveFlower, statusFlower, 'Blumen');
    safetyCheck(valveFlower, 'Blumen');
});

on({id: buttonLong, change: 'ne', val: true}, () => {
    log('🔴 Long Press → Alle schließen', 'warn');
    closeAll();
});

log('✅ HH-GA-Watering Script started', 'info');
