// =============================================
// HH-GA-Watering-Valve Control Script (Haozee 2-Zone)
// =============================================

const buttonSingle = 'zigbee.0.a4c138068ef8ffff.single';
const buttonDouble = 'zigbee.0.a4c138068ef8ffff.double';
const buttonLong   = 'zigbee.0.a4c138068ef8ffff.long';

const valvePond    = 'zigbee.0.c02cedfffe72acf5.state_l1';     // Zone 1 - Pond
const valveFlower  = 'zigbee.0.c02cedfffe72acf5.state_l2';     // Zone 2 - Flower

const statusPond   = 'zigbee.0.c02cedfffe72acf5.valve_status_l1';
const statusFlower = 'zigbee.0.c02cedfffe72acf5.valve_status_l2';

const wateringTime = 600;                    // Watering duration in seconds (10 min)
const safetyDelay  = 5 * 60 * 1000 + 30 * 1000; // 5:30 minutes safety timer

// ==================== HELPER FUNCTIONS ====================

async function setManualMode(statusId) {
    return new Promise(resolve => {
        setState(statusId, 'manual', false);
        setTimeout(resolve, 600);
    });
}

function sendCommand(valveId, value, name) {
    setState(valveId, value, false, (err) => {
        if (err) {
            log(`Error sending command to ${name}: ${err}`, 'error');
        } else {
            log(`Command sent: ${name} → ${value ? 'OPEN' : 'CLOSED'}`, 'info');
        }
    });
}

function turnOn(valve, statusId, name) {
    setManualMode(statusId).then(() => {
        sendCommand(valve, true, name);
    });
}

function turnOff(valve, name) {
    sendCommand(valve, false, name);
}

function closeAll() {
    turnOff(valvePond, 'Pond');
    turnOff(valveFlower, 'Flower');
    log('🚨 EMERGENCY CLOSE: All valves closed', 'warn');
}

function safetyCheck(valve, name) {
    setTimeout(() => {
        getState(valve, (err, state) => {
            if (state && state.val === true) {
                log(`⚠️ SAFETY: ${name} still open after 5:30 min → closing now!`, 'warn');
                turnOff(valve, name);
            } else {
                log(`✅ ${name} was closed correctly`, 'info');
            }
        });
    }, safetyDelay);
}

// ==================== BUTTON LOGIC ====================

// Single Press → Pond (Zone 1)
on({id: buttonSingle, change: 'ne', val: true}, () => {
    log('🔘 Single Press detected → Pond watering', 'info');
    turnOn(valvePond, statusPond, 'Pond');
    safetyCheck(valvePond, 'Pond');
});

// Double Press → Flower (Zone 2)
on({id: buttonDouble, change: 'ne', val: true}, () => {
    log('🔘 Double Press detected → Flower watering', 'info');
    turnOn(valveFlower, statusFlower, 'Flower');
    safetyCheck(valveFlower, 'Flower');
});

// Long Press → Emergency close all
on({id: buttonLong, change: 'ne', val: true}, () => {
    log('🔴 Long Press detected → Emergency close all valves', 'warn');
    closeAll();
});

// Startup message
log('✅ HH-GA-Watering Script started | Safety timer: 5:30 minutes', 'info');
